# Copy to lab.env and edit paths before running scripts in this directory.
KERNEL_TREE="$HOME/src/linux-6.12.95"
INITRAMFS_IMAGE="$HOME/kernel-lab/initramfs.cpio.xz"

QEMU="qemu-system-x86_64"
KERNEL_IMAGE="arch/x86/boot/bzImage"
MEMORY="2G"
SMP="2"
KERNEL_APPEND="console=ttyS0 rdinit=/init panic=-1"
SERIAL_LOG="$PWD/qemu-serial.log"

CONFIG_TARGET="defconfig"
CLEAN_TREE="0"
MAKE_JOBS="$(nproc)"
MAKE_TARGETS="bzImage vmlinux"
