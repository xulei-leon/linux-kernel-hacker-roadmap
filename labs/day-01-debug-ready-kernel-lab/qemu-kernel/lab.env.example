# Copy to lab.env and edit paths before running scripts in this directory.
KERNEL_TREE="$HOME/src/linux"
ROOTFS_IMAGE="$HOME/rootfs.ext4"

QEMU="qemu-system-x86_64"
KERNEL_IMAGE="arch/x86/boot/bzImage"
MEMORY="2G"
SMP="2"
DRIVE_OPTS="format=raw,if=virtio"
KERNEL_APPEND="console=ttyS0 root=/dev/vda rw panic=-1"

CONFIG_TARGET="defconfig"
MAKE_JOBS="$(nproc)"
MAKE_TARGETS="bzImage vmlinux"

# Day 9 bisect helpers use these when automating a serial console login.
LOGIN_PROMPT="login:"
LOGIN_USER="root"
LOGIN_PASSWORD=""
SHELL_PROMPT="# "
TRIGGER_COMMAND="uname -a"
BAD_PATTERN="BUG: unable to handle page fault"
QEMU_TIMEOUT="120"
